{
  "name": "ZonaLimpieza",
  "type": "object",
  "properties": {
    "business_id": {
      "type": "string"
    },
    "nombre": {
      "type": "string"
    },
    "ubicacion": {
      "type": "string"
    },
    "descripcion": {
      "type": "string"
    },
    "foto_url": {
      "type": "string"
    }
  },
  "required": [
    "business_id",
    "nombre"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}